# =============================================================================
# WhatsApp AI Bot v1.0 - Environment Configuration
# =============================================================================
# Copy this to .env and fill in your settings:
#   cp .env.example .env

# --- AI PROVIDER ---
# Options: gemini | openai | groq | ollama | custom
#
# GEMINI - free tier (20 req/day):
#   Get API key: https://aistudio.google.com/apikey
#   AI_PROVIDER=gemini
#   AI_MODEL=gemini-2.0-flash
#   AI_API_KEY=your_key_here
#
# OLLAMA - completely free & local:
#   AI_PROVIDER=ollama
#   AI_MODEL=llama3.2
#
# GROQ - free tier, very fast:
#   AI_PROVIDER=groq
#   AI_MODEL=llama-3.1-70b-versatile
#   AI_API_KEY=gsk_your_key
#   AI_BASE_URL=https://api.groq.com/openai/v1
#
# OPENAI - paid, most capable:
#   AI_PROVIDER=openai
#   AI_MODEL=gpt-4o-mini
#   AI_API_KEY=sk-your_key
#   AI_BASE_URL=https://api.openai.com/v1

AI_PROVIDER=gemini
AI_MODEL=gemini-2.0-flash
AI_API_KEY=
AI_BASE_URL=

# --- ADMIN ---
# Password used for WhatsApp authentication (!auth <password>)
# and the web dashboard login
ADMIN_PASSWORD=changeme123

# --- NODE ENV ---
NODE_ENV=production
